---
import commands from "../../data/commands.json";
import { Icon } from "astro-icon/components";
---

<div
    class="w-full max-w-4xl mx-auto p-6 bg-white/5 border border-white/10 rounded-3xl backdrop-blur-xl"
>
    <div class="flex items-center gap-3 mb-8">
        <div class="p-3 bg-green-500/20 rounded-xl text-green-400">
            <Icon name="lucide:terminal" class="w-6 h-6" />
        </div>
        <div>
            <h3 class="text-2xl font-bold text-white">
                Consola ADB & Fastboot
            </h3>
            <p class="text-gray-400 text-sm">
                Selecciona una acción técnica para generar el comando.
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <div class="space-y-6">
            {
                commands.categories.map((category) => (
                    <div class="space-y-3">
                        <h4 class="text-xs font-bold uppercase tracking-widest text-gray-500 px-2">
                            {category.name}
                        </h4>
                        <div class="flex flex-wrap gap-2">
                            {category.commands.map((cmd) => (
                                <button
                                    class="adb-cmd-btn px-4 py-2 text-sm font-medium text-gray-300 bg-white/5 border border-white/5 rounded-lg hover:bg-white/10 hover:border-white/20 transition-all active:scale-95"
                                    data-command={cmd.command}
                                    data-description={cmd.description}
                                >
                                    {cmd.label}
                                </button>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>

        <div
            class="relative flex flex-col h-full min-h-[200px] bg-black/40 rounded-2xl border border-white/10 overflow-hidden"
        >
            <div
                class="flex items-center justify-between px-4 py-2 bg-white/5 border-b border-white/10"
            >
                <span
                    class="text-[10px] font-mono text-gray-400 uppercase tracking-tighter"
                    >Terminal Output</span
                >
                <div class="flex gap-1">
                    <div class="w-2 h-2 rounded-full bg-red-500/50"></div>
                    <div class="w-2 h-2 rounded-full bg-yellow-500/50"></div>
                    <div class="w-2 h-2 rounded-full bg-green-500/50"></div>
                </div>
            </div>

            <div class="p-6 flex-1 font-mono text-sm">
                <p id="adb-display-desc" class="text-gray-500 mb-4 italic">
                    Selecciona un comando para empezar...
                </p>
                <div class="flex items-center gap-2 group">
                    <span class="text-green-500">$</span>
                    <code
                        id="adb-display-cmd"
                        class="text-blue-400 font-bold break-all">_</code
                    >
                </div>
            </div>

            <button
                id="copy-adb-btn"
                class="absolute bottom-4 right-4 p-3 bg-blue-600 hover:bg-blue-500 text-white rounded-xl shadow-lg shadow-blue-600/20 transition-all opacity-0 pointer-events-none active:scale-90"
                title="Copiar comando"
            >
                <Icon name="lucide:copy" class="w-5 h-5" />
            </button>
        </div>
    </div>
</div>

<script>
    const buttons = document.querySelectorAll(".adb-cmd-btn");
    const displayCmd = document.getElementById("adb-display-cmd");
    const displayDesc = document.getElementById("adb-display-desc");
    const copyBtn = document.getElementById("copy-adb-btn");

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            buttons.forEach((b) =>
                b.classList.remove(
                    "bg-blue-600/20",
                    "border-blue-500/50",
                    "text-blue-300",
                ),
            );
            btn.classList.add(
                "bg-blue-600/20",
                "border-blue-500/50",
                "text-blue-300",
            );

            const cmd = btn.getAttribute("data-command");
            const desc = btn.getAttribute("data-description");

            if (cmd && desc && displayCmd && displayDesc && copyBtn) {
                displayCmd.textContent = cmd;
                displayDesc.textContent = desc;

                copyBtn.classList.remove("opacity-0", "pointer-events-none");
                copyBtn.setAttribute("data-to-copy", cmd);
            }
        });
    });

    copyBtn?.addEventListener("click", () => {
        const cmd = copyBtn.getAttribute("data-to-copy");
        if (cmd) {
            navigator.clipboard.writeText(cmd);

            const originalIcon = copyBtn.innerHTML;
            copyBtn.innerHTML =
                '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><path d="M20 6 9 17l-5-5"/></svg>';
            copyBtn.classList.replace("bg-blue-600", "bg-green-600");

            setTimeout(() => {
                copyBtn.innerHTML = originalIcon;
                copyBtn.classList.replace("bg-green-600", "bg-blue-600");
            }, 2000);
        }
    });
</script>
