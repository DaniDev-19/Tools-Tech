---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Tools-Tech Hub | Soporte Técnico Avanzado",
	description = "Hub de herramientas para soporte técnico: ADB Console, Android Intents, Descargas y Guías SEO de desbloqueo.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta name="google-adsense-account" content="ca-pub-6647054733269068" />
		<script
			is:inline
			async
			src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6647054733269068"
			crossorigin="anonymous"></script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/tech-tools.png" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="/tech-tools.png" />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="bg-[#181616] min-h-screen relative overflow-x-hidden">
		<div
			class="fixed inset-0 pointer-events-none -z-10 select-none"
			aria-hidden="true"
		>
			<div
				class="absolute bg-blue-500/30 w-64 h-64 right-10 top-10 rounded-full mix-blend-screen filter blur-3xl animate-blur"
			>
			</div>
			<div
				class="absolute bg-green-600/30 w-72 h-72 right-1/4 top-1/2 rounded-full mix-blend-screen filter blur-3xl animate-float"
			>
			</div>
			<div
				class="absolute bg-purple-500/20 w-56 h-56 left-10 bottom-10 rounded-full mix-blend-screen filter blur-3xl animate-blur"
			>
			</div>
		</div>

		<slot />
		<Footer />
		<style is:global>
			@reference "tailwindcss";

			::-webkit-scrollbar {
				width: 8px;
			}
			::-webkit-scrollbar-track {
				background: #181616;
			}
			::-webkit-scrollbar-thumb {
				background: linear-gradient(to bottom, #2563eb, #06b6d4);
				border-radius: 10px;
				border: 2px solid #181616;
			}
			::-webkit-scrollbar-thumb:hover {
				background: linear-gradient(to bottom, #3b82f6, #22d3ee);
				box-shadow: 0 0 10px rgba(6, 182, 212, 0.5);
			}

			html {
				scroll-behavior: smooth;
			}
		</style>
	</body>
</html>
